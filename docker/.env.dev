# ==========================================
# Development Environment Variables
# ==========================================
# Var names must match backend/app/core/config.py Settings fields

# Database
DB_USER=admin
DB_PASS=dev_password_only
DB_NAME=trading_log

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0

# JWT
SECRET_KEY=dev-secret-change-in-production
JWT_ALGORITHM=HS256

# Encryption
ENCRYPTION_KEY=ZGV2LWVuY3J5cHRpb24ta2V5LWNoYW5nZS1pbi1wcm9k

# CORS (comma-separated, NO brackets)
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# App
APP_ENV=development
DEBUG=true
LOG_LEVEL=DEBUG
