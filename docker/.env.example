# ==========================================
# AI Trader v2 – Development Environment
# ==========================================

# App
APP_ENV=development
DEBUG=true
LOG_LEVEL=DEBUG
SECRET_KEY=dev-secret-key-not-for-production-use-only

# Database
DB_HOST=db
DB_PORT=5432
DB_USER=admin
DB_PASS=dev_password_only
DB_NAME=trading_log

# Redis
REDIS_HOST=redis
REDIS_PORT=6379

# JWT
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

# CORS
CORS_ORIGINS=http://localhost:3100,http://127.0.0.1:3100

# MT5 Bridge (Windows VPS)
WINDOWS_IP=
SYMBOL=XAUUSD

# AI Providers (configure via UI, these are fallback defaults)
OPENROUTER_API_KEY=
OPENROUTER_URL=https://openrouter.ai/api/v1/chat/completions
MODEL=anthropic/claude-3-haiku

# Risk Management Defaults
ACCOUNT_BALANCE=1000.00
RISK_PERCENT=1.0
SL_POINTS=300
TP_POINTS=600

# Encryption Key (for API keys stored in DB)
ENCRYPTION_KEY=dev-encryption-key-32-bytes-long!

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000
