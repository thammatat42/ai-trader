# ==========================================
# AI PROVIDER SELECTION
# ==========================================
# เลือก provider: "openrouter" หรือ "nvidia"
AI_PROVIDER=openrouter

# ==========================================
# OPENROUTER AI SETTINGS
# ==========================================
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxx
OPENROUTER_URL=https://openrouter.ai/api/v1/chat/completions
MODEL=anthropic/claude-3-haiku

# ==========================================
# NVIDIA AI SETTINGS (build.nvidia.com)
# ==========================================
NVIDIA_API_KEY=nvapi-xxxxxxxxxxxxxxxxxxxxxxxx
NVIDIA_URL=https://integrate.api.nvidia.com/v1/chat/completions
NVIDIA_MODEL=meta/llama-3.1-70b-instruct

# ==========================================
# SHARED AI SETTINGS
# ==========================================
MAX_TOKENS=300
TEMPERATURE=0.1

# ==========================================
# NODE CONNECTION (WINDOWS VPS)
# ==========================================
WINDOWS_IP=123.45.67.89
SYMBOL=XAUUSD

# ==========================================
# DATABASE SETTINGS (POSTGRESQL)
# ==========================================
DB_HOST=db
DB_USER=admin
DB_PASS=secretpassword
DB_NAME=trading_log

# ==========================================
# REDIS SETTINGS (Market Journal & Cache)
# ==========================================
REDIS_HOST=redis
REDIS_PORT=6379

# ==========================================
# NEWS & MACRO EVENTS (Finnhub – free tier)
# ==========================================
# สมัครฟรีที่ https://finnhub.io/ → ได้ API key
FINNHUB_API_KEY=your-finnhub-api-key-here

# ==========================================
# RISK MANAGEMENT SETTINGS
# ==========================================
ACCOUNT_BALANCE=1000.00
RISK_PERCENT=1.0
SL_POINTS=300
TP_POINTS=600

# ==========================================
# BOT LOOP SETTINGS (ค่าเริ่มต้น – ปรับได้จาก Dashboard)
# ==========================================
# BOT_INTERVAL=300          # วินาที (ถูก override โดย DB bot_settings)
# CONSECUTIVE_ERR_LIMIT=5   # หยุดอัตโนมัติหลังผิดพลาดติดต่อกัน N ครั้ง